{
  "name": "watchthat",
  "version": "0.2.0",
  "private": true,
  "description": "Know when websites change.",
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "prebuild": "NODE_ENV=test jest --ci",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "test": "jest --watch",
    "test:ci": "NODE_ENV=test jest --ci",
    "lint": "tsc --noEmit",
    "scan:secrets": "bash scripts/scan-secrets.sh",
    "e2e": "PLAYWRIGHT_LOCAL=1 playwright test",
    "e2e:smoke": "PLAYWRIGHT_LOCAL=1 playwright test --grep @smoke",
    "e2e:full": "PLAYWRIGHT_LOCAL=1 playwright test --grep @full",
    "e2e:install": "playwright install --with-deps chromium",
    "eval": "promptfoo eval -c evals/promptfooconfig.yaml --env-file .env.local",
    "eval:view": "promptfoo view"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@copilotkit/react-core": "^1.55.1",
    "@copilotkit/runtime": "^1.55.1",
    "@mendable/firecrawl-js": "^4.18.1",
    "@sentry/nextjs": "^10.49.0",
    "@sentry/profiling-node": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@vercel/analytics": "^2.0.1",
    "jszip": "^3.10.1",
    "langfuse": "^3.38.20",
    "next": "^15.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.49",
    "promptfoo": "^0.121.12",
    "tailwindcss": "^3.4.16",
    "ts-jest": "^29.2.5",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@sentry/cli",
      "@sentry-internal/node-cpu-profiler",
      "sharp",
      "@swc/core"
    ]
  }
}

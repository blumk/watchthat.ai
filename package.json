{
  "name": "watchthat",
  "version": "0.2.0",
  "private": true,
  "description": "Know when websites change.",
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "prebuild": "NODE_ENV=test jest --ci",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "test": "jest --watch",
    "test:ci": "NODE_ENV=test jest --ci",
    "lint": "tsc --noEmit",
    "scan:secrets": "bash scripts/scan-secrets.sh"
  },
  "dependencies": {

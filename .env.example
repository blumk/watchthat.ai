# External APIs
FIRECRAWL_API_KEY=fc-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# Supabase (project settings → API)
# URL and publishable key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only. Used by API routes to write to shared pages/snapshots tables
# and to the screenshots storage bucket. Bypasses RLS — never ship to client.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Shared secret authenticating /api/cron/scrape calls from Supabase pg_cron.
# Must match the 'cron_secret' entry in Supabase Vault (see README →
# Auto-refresh). Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional override for the public base URL used to build og:url values on
# /p/<id> share pages. On Vercel this is auto-detected from VERCEL_URL /
# VERCEL_PROJECT_PRODUCTION_URL, so you typically don't need to set this.
# Set it only when the auto-detected host is wrong (e.g. custom proxy in
# front of Vercel). Defaults to https://watchthat.ai otherwise.
# NEXT_PUBLIC_APP_URL=https://example.com
